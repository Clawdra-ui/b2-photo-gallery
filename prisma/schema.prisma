generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model IndexedFile {
  id           String   @id @default(cuid())
  objectKey    String   @unique
  filename     String
  folderPath   String
  size         Int
  lastModified DateTime
  contentType  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}